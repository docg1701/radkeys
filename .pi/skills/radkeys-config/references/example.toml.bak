# ═══════════════════════════════════════════════════════════════════════════
# xray_hand_phalanx — Phalanx Fracture
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "xray_hand_phalanx"
name = "Phalanx Fracture"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Tuft Fx"
  action = "text"
  content = """PA and lateral views of the left ring finger.

Comminuted fracture through distal phalangeal tuft. No intra-articular
extension. Nail bed intact radiographically.

IMPRESSION: Comminuted tuft fracture, left ring finger. Protective
splinting. Clinical evaluation for nail bed injury."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Mallet"
  action = "text"
  content = """Lateral view of the right index finger.

Small avulsion fracture at dorsal base of distal phalanx at extensor
tendon insertion, with ~20 degrees DIP flexion (mallet deformity).
No volar subluxation.

IMPRESSION: Mallet finger (bony avulsion). Continuous DIP extension
splinting for 6-8 weeks."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Jersey"
  action = "text"
  content = """Lateral view of the right ring finger.

Avulsion fracture at volar base of middle phalanx at FDP insertion
with ~30 degrees PIP flexion. No proximal retraction of avulsed
fragment.

IMPRESSION: Jersey finger (FDP avulsion). Urgent hand surgery — delays
beyond 7-10 days significantly reduce success rates."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
