# ═══════════════════════════════════════════════════════════════════════════
# mri_spine_lumbar_disc — Disc Disease
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "mri_spine_lumbar_disc"
name = "Disc Disease"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Bulge L4-5"
  action = "text"
  content = """MRI of the lumbar spine without contrast.

Broad-based disc bulge at L4-L5 effacing anterior thecal sac without
significant canal stenosis. No herniation, extrusion, or nerve root
compression. Remaining discs normal.

IMPRESSION: L4-L5 disc bulge without stenosis or nerve compression.
Conservative management."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Hernia L5-S1"
  action = "text"
  content = """MRI of the lumbar spine without contrast.

Left paracentral disc herniation at L5-S1 measuring ~6 mm AP. Contacts
and slightly displaces traversing left S1 nerve root. Mild left
foraminal narrowing. No canal stenosis.

IMPRESSION: Left L5-S1 disc herniation with S1 nerve root contact.
Pain management or neurosurgical microdiscectomy."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Extrusion"
  action = "text"
  content = """MRI of the lumbar spine without contrast.

Large right paracentral disc extrusion at L4-L5 measuring 8 mm and
migrating inferiorly behind L5 body. Extruded fragment compresses
traversing right L5 nerve root within lateral recess. Moderate right
foraminal stenosis.

IMPRESSION: Large right L4-L5 disc extrusion with inferior migration
and L5 nerve root compression. Urgent neurosurgical microdiscectomy."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
