  action = "line_end"
  [[screens.buttons]]
  row = 4
  col = 3
  label = "Del"
  action = "delete"
  [[screens.buttons]]
  row = 5
  col = 0
  label = "Back"
  action = "prev"
  [[screens.buttons]]
  row = 5
  col = 1
  label = "Home"
  action = "home"
  [[screens.buttons]]
  row = 5
  col = 2
  label = "SelAll"
  action = "select_all"
  [[screens.buttons]]
  row = 5
  col = 3
  label = "Copy"
  action = "copy"
  [[screens.buttons]]
  row = 5
  col = 4
  label = "Paste"
  action = "paste"
  [[screens.buttons]]
  row = 5
  col = 5
  label = "Bksp"
  action = "backspace"

