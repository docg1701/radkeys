# xray_hand_degen — Degenerative Hand
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "xray_hand_degen"
name = "Degenerative Hand"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "CMC OA"
  action = "text"
  content = """PA view of both hands.

Moderate first CMC joint space narrowing and subchondral sclerosis
bilaterally, right > left. Small osteophytes.

IMPRESSION: Bilateral first CMC OA, moderate on right."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Erosive OA"
  action = "text"
  content = """PA view of both hands.

DIP and PIP joint space narrowing with central subchondral erosions
("gull-wing" deformity) and marginal osteophytes. No periarticular
osteopenia or marginal erosions to suggest RA.

IMPRESSION: Erosive OA ("gull-wing" pattern). Rheumatology correlation."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "CPPD"
  action = "text"
  content = """PA view of the right hand.

Chondrocalcinosis of the TFCC and radiocarpal joint, consistent with
CPPD crystal deposition disease. Mild radiocarpal narrowing.

IMPRESSION: Chondrocalcinosis of the wrist (CPPD arthropathy).
Correlate for pseudogout."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
