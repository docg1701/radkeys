# ═══════════════════════════════════════════════════════════════════════════
# xray_hand_distal — Distal Radius Fx
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "xray_hand_distal"
name = "Distal Radius Fx"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Colles"
  action = "text"
  content = """PA and lateral views of the left wrist.

Transverse fracture of distal radial metaphysis with dorsal angulation
of ~20 degrees and dorsal comminution. Ulna intact. Radiocarpal and
DRUJ congruent. Radial height decreased 3 mm.

IMPRESSION: Colles fracture with dorsal angulation. Orthopedic
evaluation for closed reduction and casting."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Smith"
  action = "text"
  content = """PA and lateral views of the right wrist.

Transverse fracture of distal radial metaphysis with volar angulation
of ~15 degrees. Ulna intact. Radiocarpal and DRUJ congruent.

IMPRESSION: Smith fracture (reverse Colles) with volar angulation.
These are typically unstable — surgical fixation often required."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Barton"
  action = "text"
  content = """PA and lateral views of the left wrist.

Intra-articular fracture of dorsal rim of distal radius with dorsal
carpal subluxation, consistent with dorsal Barton fracture. Fragment
involves ~40% of articular surface with 2 mm step-off.

IMPRESSION: Dorsal Barton fracture with carpal subluxation. Urgent
orthopedic evaluation for ORIF."""
  [[screens.buttons]]
  row = 0
  col = 3
  label = "Chauffeur"
  action = "text"
  content = """PA and lateral views of the right wrist.

Intra-articular fracture through radial styloid process, consistent
with chauffeur (Hutchinson) fracture. Fracture extends obliquely to
scaphoid facet. Minimal displacement (< 2 mm).

IMPRESSION: Radial styloid fracture (chauffeur fracture), minimally
displaced. Orthopedic follow-up for possible percutaneous pinning."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
  [[screens.buttons]]
  row = 4
  col = 2
  label = "LEnd"
  action = "line_end"
  [[screens.buttons]]
  row = 4
  col = 3
  label = "Del"
  action = "delete"
  [[screens.buttons]]
  row = 5
  col = 0
  label = "Back"
  action = "prev"
  [[screens.buttons]]
  row = 5
  col = 1
  label = "Home"
  action = "home"
  [[screens.buttons]]
