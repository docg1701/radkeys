# us_abdomen_liver — Liver US
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "us_abdomen_liver"
name = "Liver US"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal"
  action = "text"
  content = """Ultrasound of the liver.

Liver normal in size (span 14.5 cm) with smooth contour and homogeneous
echotexture. No focal lesions. Hepatic vasculature patent with normal
flow. Biliary tree nondilated. CBD 3 mm.

IMPRESSION: Normal liver ultrasound."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Steatosis"
  action = "text"
  content = """Ultrasound of the liver.

Liver enlarged (span 17.2 cm) with diffusely increased echogenicity
compared to right renal cortex. Posterior beam attenuation with
decreased visualization of hepatic vessels and diaphragm. No focal
lesions. Patent vasculature.

IMPRESSION: Moderate to severe hepatic steatosis. Correlate for
metabolic syndrome, NAFLD, and alcohol use."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Cirrhosis"
  action = "text"
  content = """Ultrasound of the liver.

Liver with nodular contour and coarse, heterogeneous echotexture
consistent with cirrhosis. Right lobe atrophy with relative caudate
hypertrophy. Mild splenomegaly (13.5 cm). No focal lesions. Patent
portal vein with hepatopetal flow. No ascites.

IMPRESSION: Cirrhosis with portal hypertension (splenomegaly).
Hepatology follow-up for HCC screening."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
