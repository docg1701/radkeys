# us_abdomen_gb — Gallbladder US
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "us_abdomen_gb"
name = "Gallbladder US"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal"
  action = "text"
  content = """RUQ ultrasound (gallbladder).

Gallbladder distended with thin walls (2 mm). No stones, sludge, or
polyps. No pericholecystic fluid. Sonographic Murphy sign negative.
CBD 3 mm. No intrahepatic biliary dilation.

IMPRESSION: Normal gallbladder ultrasound."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Cholecystitis"
  action = "text"
  content = """RUQ ultrasound.

Gallbladder distended with wall thickening (6 mm) and pericholecystic
fluid. Multiple shadowing gallstones including one impacted at neck.
Sonographic Murphy sign positive. CBD 5 mm. No intrahepatic dilation.

IMPRESSION: Acute calculous cholecystitis with impacted neck stone.
Surgical consultation for cholecystectomy."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Polyp"
  action = "text"
  content = """RUQ ultrasound.

Non-shadowing, non-mobile polypoid lesion measuring 7 mm in gallbladder
fundus. No vascularity on color Doppler. No other lesions. Wall thin.
No stones or sludge. Murphy sign negative.

IMPRESSION: 7 mm gallbladder polyp, likely benign. Follow-up US in
6 and 12 months. Surgical consultation if > 10 mm."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
