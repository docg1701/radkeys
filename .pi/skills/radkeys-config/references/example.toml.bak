# ═══════════════════════════════════════════════════════════════════════════
# ct_head — Head CT
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "ct_head"
name = "Head CT"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal"
  action = "text"
  content = """Non-contrast CT of the head.

No acute intracranial hemorrhage, mass effect, or midline shift.
Ventricles and sulci age-appropriate. Gray-white differentiation
preserved. Posterior fossa unremarkable. No calvarial fracture.

IMPRESSION: Normal non-contrast head CT."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "SAH"
  action = "text"
  content = """Non-contrast CT of the head.

Acute hyperdensity in basal cisterns and Sylvian fissures bilaterally,
consistent with acute SAH (Fisher grade 3). Mild ventricular dilatation
concerning for early hydrocephalus. No parenchymal hematoma.

IMPRESSION: Acute SAH (Fisher 3) with early hydrocephalus. Emergent
neurosurgical consultation. CTA for aneurysm evaluation."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "SDH Acute"
  action = "text"
  content = """Non-contrast CT of the head.

Crescent-shaped hyperdense extra-axial collection up to 12 mm over
right cerebral convexity — acute SDH. Associated mass effect with
~8 mm right-to-left midline shift, partial effacement of right
lateral ventricle, and uncal herniation.

IMPRESSION: Large acute right SDH with mass effect and uncal
herniation. Emergent neurosurgical intervention indicated."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
  [[screens.buttons]]
  row = 4
  col = 2
  label = "LEnd"
  action = "line_end"
  [[screens.buttons]]
  row = 4
  col = 3
  label = "Del"
  action = "delete"
  [[screens.buttons]]
  row = 5
  col = 0
  label = "Back"
  action = "prev"
  [[screens.buttons]]
  row = 5
  col = 1
  label = "Home"
  action = "home"
  [[screens.buttons]]
  row = 5
  col = 2
