[[screens]]
id = "xray_bone_age"
name = "Bone Age"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal (GP)"
  action = "text"
  content = """Left hand and wrist radiograph for bone age assessment.

Bone age is consistent with chronological age per Greulich and Pyle
standards. All carpals, metacarpals, and phalanges show age-appropriate
ossification.

IMPRESSION: Normal bone age per Greulich and Pyle atlas."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Delayed"
  action = "text"
  content = """Left hand and wrist radiograph for bone age assessment.

Bone age delayed by ~2 SD compared to chronological age per Greulich
and Pyle standards. Carpal ossification lags chronologic age.

IMPRESSION: Delayed bone age. Endocrinological correlation recommended."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Advanced"
  action = "text"
  content = """Left hand and wrist radiograph for bone age assessment.

Bone age advanced by ~2 SD compared to chronological age per Greulich
and Pyle standards.

IMPRESSION: Advanced bone age. Endocrinological correlation recommended."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
