# ═══════════════════════════════════════════════════════════════════════════
# ct_chest_pe — Pulmonary Embolism
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "ct_chest_pe"
name = "Pulmonary Embolism"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Acute PE"
  action = "text"
  content = """CTPA.

Bilateral filling defects within main pulmonary arteries extending
into lobar and segmental branches — acute PE. Right ventricular
dilation with straightening of IVS (RV/LV > 1.0) suggesting right
heart strain. Small wedge-shaped peripheral opacity RLL consistent
with pulmonary infarction. No effusion.

IMPRESSION: Acute bilateral PE with right heart strain. Immediate
anticoagulation and risk stratification."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Chronic PE"
  action = "text"
  content = """CTPA.

Eccentric, peripherally located filling defects within segmental
branches of both lower lobe PAs forming obtuse angles with vessel
wall — chronic PE. Mosaic perfusion, enlarged bronchial arteries,
mild PA dilation (32 mm).

IMPRESSION: Chronic PE with CT features of pulmonary hypertension.
V/Q scintigraphy and echocardiography recommended."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Saddle PE"
  action = "text"
  content = """CTPA.

Large saddle embolus straddling bifurcation of main PA, extending
into both right and left main PAs. Significant RV dilation (RV/LV 1.4)
with bowing of IVS. No infarction identified.

IMPRESSION: Saddle PE with right heart strain and impending
hemodynamic compromise. Medical emergency — immediate thrombolysis
or embolectomy indicated."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
  [[screens.buttons]]
  row = 4
  col = 2
  label = "LEnd"
  action = "line_end"
  [[screens.buttons]]
  row = 4
  col = 3
  label = "Del"
  action = "delete"
  [[screens.buttons]]
