# ═══════════════════════════════════════════════════════════════════════════
# mri_spine_cervical — Cervical Spine
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "mri_spine_cervical"
name = "Cervical Spine"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal"
  action = "text"
  content = """MRI of the cervical spine without contrast.

TECHNIQUE: Sagittal T1, T2, STIR and axial T2.

FINDINGS: Normal cervical lordosis and alignment. Normal marrow signal.
Discs normal in height and signal. No herniation, bulge, or osteophyte.
Spinal canal and foramina patent. Cord normal signal and caliber.
No syrinx. Craniocervical junction unremarkable.

IMPRESSION: Normal MRI of the cervical spine."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Myelopathy"
  action = "text"
  content = """MRI of the cervical spine without contrast.

Large posterior disc-osteophyte complex at C5-C6 effacing ventral
thecal sac and flattening cord. T2 hyperintensity in cord at this
level consistent with myelomalacia. Moderate central canal stenosis
(AP 7 mm). Mild disc bulges at C4-C5 and C6-C7 without cord
compression.

IMPRESSION: C5-C6 disc-osteophyte complex with cord compression and
myelomalacia. Neurosurgical evaluation for ACDF."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
