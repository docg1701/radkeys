# ═══════════════════════════════════════════════════════════════════════════
# mri_brain — Brain MRI
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "mri_brain"
name = "Brain MRI"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal"
  action = "text"
  content = """MRI of the brain without contrast.

TECHNIQUE: Multiplanar multisequence MRI without IV contrast (T1, T2,
FLAIR, DWI/ADC, SWI).

FINDINGS: Normal brain parenchyma. No acute infarct (DWI/ADC negative).
Normal gray-white differentiation. Ventricles and sulci age-appropriate.
No mass, mass effect, or midline shift. Normal flow voids in major
intracranial vessels. Sella, brainstem, posterior fossa unremarkable.

IMPRESSION: Normal MRI of the brain without contrast."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "CVA Acute"
  action = "text"
  content = """MRI of the brain without contrast.

TECHNIQUE: Multiplanar multisequence MRI without IV contrast.

FINDINGS: Area of restricted diffusion (DWI+, ADC-) in left MCA
territory involving insular cortex and frontal operculum. Correlating
T2/FLAIR hyperintensity. No hemorrhagic transformation on SWI. No
significant mass effect or midline shift.

IMPRESSION: Acute infarct, left MCA territory (insular ribbon and
frontal operculum). Neurology consultation and stroke workup."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "MS Plaques"
  action = "text"
  content = """MRI of the brain without and with IV contrast.

Multiple periventricular and juxtacortical ovoid T2/FLAIR hyperintense
lesions perpendicular to corpus callosum ("Dawson's fingers"). Several
T1 hypointense ("black holes"). One left frontal lesion with incomplete
rim enhancement. Corpus callosum involvement. No restricted diffusion.

IMPRESSION: Multiple supratentorial white matter lesions characteristic
of MS. Active enhancing lesion. Neurology follow-up recommended."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
  [[screens.buttons]]
  row = 4
  col = 2
  label = "LEnd"
  action = "line_end"
  [[screens.buttons]]
  row = 4
  col = 3
  label = "Del"
  action = "delete"
  [[screens.buttons]]
  row = 5
  col = 0
  label = "Back"
  action = "prev"
  [[screens.buttons]]
  row = 5
  col = 1
  label = "Home"
  action = "home"
  [[screens.buttons]]
  row = 5
  col = 2
  label = "SelAll"
  action = "select_all"
  [[screens.buttons]]
