# ═══════════════════════════════════════════════════════════════════════════
# xray_elbow — Elbow X-Ray
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "xray_elbow"
name = "Elbow X-Ray"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal"
  action = "text"
  content = """AP and lateral views of the right elbow.

Normal alignment and mineralization. No fracture or dislocation.
Joint spaces preserved. Anterior fat pad sign negative; posterior
fat pad absent. Soft tissues unremarkable.

IMPRESSION: Normal right elbow radiographs."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Fat Pad+"
  action = "text"
  content = """AP and lateral views of the left elbow following trauma.

Positive posterior fat pad sign and elevated anterior fat pad
("sail sign"), indicating joint effusion. No discrete fracture line.

IMPRESSION: Joint effusion with positive fat pad signs. Occult radial
head or supracondylar fracture suspected. Follow-up in 10-14 days."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Rad Head"
  action = "text"
  content = """AP and lateral views of the right elbow.

Minimally displaced transverse fracture through radial head involving
~25% of articular surface with < 2 mm step-off (Mason type I). Moderate
joint effusion with elevated fat pads. No other fractures.

IMPRESSION: Mason type I radial head fracture. Conservative management
with early range of motion. Orthopedic follow-up."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
  [[screens.buttons]]
  row = 4
  col = 2
  label = "LEnd"
  action = "line_end"
  [[screens.buttons]]
  row = 4
  col = 3
  label = "Del"
  action = "delete"
  [[screens.buttons]]
  row = 5
  col = 0
  label = "Back"
  action = "prev"
  [[screens.buttons]]
  row = 5
  col = 1
  label = "Home"
  action = "home"
  [[screens.buttons]]
  row = 5
  col = 2
  label = "SelAll"
  action = "select_all"
  [[screens.buttons]]
  row = 5
  col = 3
  label = "Copy"
  action = "copy"
  [[screens.buttons]]
  row = 5
