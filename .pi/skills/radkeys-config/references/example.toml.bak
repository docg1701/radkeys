# ═══════════════════════════════════════════════════════════════════════════
# xray_hand_scaphoid — Scaphoid Fracture
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "xray_hand_scaphoid"
name = "Scaphoid Fracture"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Waist Fx"
  action = "text"
  content = """PA, oblique, and scaphoid views of the right wrist.

Transverse lucent line through scaphoid waist with ~1 mm cortical
offset. No sclerosis or cystic change. Scapholunate interval normal.

IMPRESSION: Acute scaphoid waist fracture, minimally displaced.
Thumb spica cast for 6-12 weeks. Follow-up at 6 and 12 weeks."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Prox Pole"
  action = "text"
  content = """PA, oblique, and scaphoid views of the left wrist.

Subtle lucency at proximal pole of scaphoid with 1 mm sclerosis of
proximal fragment. No significant displacement. Scapholunate interval
preserved.

IMPRESSION: Proximal pole scaphoid fracture. Due to tenuous blood
supply, orthopedic evaluation for surgical fixation recommended."""
  [[screens.buttons]]
  row = 0
  col = 2
  label = "Nonunion"
  action = "text"
  content = """PA, oblique, and scaphoid views of the right wrist.

Well-defined lucent defect through scaphoid waist with smooth,
sclerotic margins and 2 mm diastasis — established nonunion. Cystic
change in proximal fragment suggesting AVN. DISI deformity present.

IMPRESSION: Scaphoid waist nonunion with AVN and DISI. Urgent hand
surgery referral for bone grafting and internal fixation."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
  [[screens.buttons]]
  row = 4
