# =============================================================================
# RadKeys — Reference Example Config (TOML)
# =============================================================================
#
# 39 screens, max depth 6 levels, ALL 13 actions exercised.
# Every screen has row-4 (SLine, LStart, LEnd, Del) + row-5 (Back, Home,
# SelAll, Copy, Paste, Bksp) for full editing control.
# EXEC buttons ONLY on the utilities screen (root level = L2).
#
# LONGEST CHAINS:
#   6 levels: root → xray_menu → xray_extremities → xray_hand
#                   → xray_hand_trauma → xray_hand_scaphoid (also distal, metacarp, phalanx)
#   5 levels: root → ct_menu → ct_chest → ct_chest_vascular → ct_chest_pe
#   5 levels: root → mri_menu → mri_spine → mri_spine_lumbar
#                   → mri_spine_lumbar_disc (also stenosis)
#   4 levels: root → us_menu → us_abdomen → us_abdomen_liver (also gallbladder)
#
# WARNING: BurntSushi/toml does NOT preserve comments on save.
# A .bak backup is created automatically — restore from it.

[app]
name = "RadKeys"
radiologist = "Dr. Galvani"
language = "en"

[app.device]
vendor_id = 0x1234
product_id = 0xABCD
protocol = "radkeys-diy"

[app.layout]
columns = 6
rows = 6

[app.theme]
preset = "dracula"


# ═══════════════════════════════════════════════════════════════════════════
# root — RadKeys Home
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "root"
name = "RadKeys Home"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "X-Ray"
  action = "navigate"
  target = "xray_menu"
  [[screens.buttons]]
  row = 0
  col = 1
  label = "CT"
  action = "navigate"
  target = "ct_menu"
