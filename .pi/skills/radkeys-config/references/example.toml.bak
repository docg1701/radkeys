# xray_scoliosis — Scoliosis Series
# ═══════════════════════════════════════════════════════════════════════════

[[screens]]
id = "xray_scoliosis"
name = "Scoliosis Series"
  [[screens.buttons]]
  row = 0
  col = 0
  label = "Normal"
  action = "text"
  content = """Full spine PA and lateral radiographs for scoliosis evaluation.

Normal spinal alignment without significant coronal or sagittal
deformity. No vertebral anomalies, fractures, or destructive lesions.
Risser sign appropriate for age.

IMPRESSION: No significant scoliosis. Normal spinal alignment."""
  [[screens.buttons]]
  row = 0
  col = 1
  label = "Idiopathic"
  action = "text"
  content = """Full spine PA and lateral radiographs for scoliosis evaluation.

Right thoracic curve with apex at T8-T9 measuring ~18 degrees (Cobb
angle), consistent with adolescent idiopathic scoliosis. No vertebral
rotation or structural anomalies. Risser sign grade 3.

IMPRESSION: Adolescent idiopathic scoliosis, 18-degree right thoracic
curve. Orthopedic follow-up recommended."""
  [[screens.buttons]]
  row = 4
  col = 0
  label = "SLine"
  action = "select_line"
  [[screens.buttons]]
  row = 4
  col = 1
  label = "LStart"
  action = "line_start"
